spring.application.name=skincare-api

# Puerto — Cloud Run inyecta $PORT automáticamente; 8080 es el fallback local
server.port=${PORT:8080}
# Necesario para que Swagger funcione correctamente tras el proxy HTTPS de Cloud Run
server.forward-headers-strategy=framework

# ── Base de datos — Cloud SQL via Socket Factory ─────────────────────────────
# Obtén INSTANCE_CONNECTION_NAME en: GCP > Cloud SQL > tu instancia > Resumen
spring.datasource.url=jdbc:postgresql://google/skincare?cloudSqlInstance=${INSTANCE_CONNECTION_NAME}&socketFactory=com.google.cloud.sql.postgres.SocketFactory
spring.datasource.username=${DB_USER}
spring.datasource.password=${DB_PASSWORD}

spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.hikari.maximum-pool-size=2

spring.jpa.hibernate.ddl-auto=update
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.show-sql=true

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por comas; agrega tu dominio de Firebase Hosting al desplegar
cors.allowed-origins=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,https://<tu-proyecto>.web.app,https://<tu-proyecto>.firebaseapp.com
